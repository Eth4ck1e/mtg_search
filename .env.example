# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as the schema reference.

# Postgres connection URL. Local dev assumes the docker-compose stack
# brought up in Phase 1.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mtg_search

# Anthropic API key for the HyDE query rewriter.
# Not required until Phase 4. Leave blank during Phase 1-3.
ANTHROPIC_API_KEY=

# Overrides for the embedding model. Defaults in src/config.py are the
# values committed to in CLAUDE.md; override here only for experiments.
# EMBEDDING_MODEL=sentence-transformers/multi-qa-distilbert-cos-v1
# EMBEDDING_DIM=768
# MAX_LENGTH=512

# Override the HyDE model. Default is Claude Haiku 4.5 — cheap + fast,
# upgrade to Sonnet if rewrite quality is the bottleneck.
# HYDE_MODEL=claude-haiku-4-5-20251001
